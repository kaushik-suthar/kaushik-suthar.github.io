// ════════════════════════════════════════════════════════════════════════════
//  iNDEED — Firestore Security Rules
//  ----------------------------------------------------------------------------
//  Deploy these in Firebase Console → Firestore Database → Rules (or via
//  `firebase deploy --only firestore:rules` if you use the CLI).
//
//  What this does: every document lives under users/{uid}/..., and this rule
//  only allows a request to read/write a given uid's subtree if the request
//  is authenticated AND the authenticated uid matches that path's uid. A
//  signed-in user can never read or write another user's data.
// ════════════════════════════════════════════════════════════════════════════
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    // Everything else is denied by default (no other matches = no access).
  }
}
